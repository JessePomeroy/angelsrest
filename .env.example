# ============================================================================
# angelsrest — Environment Variables
# ============================================================================
# Copy this file to .env.local (for dev) and set real values.
# NEVER commit a file named .env or .env.production with real secrets.
# `.gitignore` already excludes .env*, but the generic filename is a footgun.
#
# In production, all of these must be set in Vercel → Settings → Environment
# Variables AND in Convex → `npx convex env set <NAME> <VALUE>` (for the subset
# read by Convex functions, marked [convex] below).
# ============================================================================

# ----- Site -----
PUBLIC_SITE_URL=http://localhost:5173

# ----- Convex -----
# Deployment used by `npx convex dev`. The Convex source lives in
# packages/crm-api/, so run Convex commands there; they read
# CONVEX_DEPLOYMENT from packages/crm-api/.env.local.
# See packages/crm-api/.env.example. CONVEX_DEPLOYMENT is duplicated here
# for any tooling that still expects it at the repo root.
CONVEX_DEPLOYMENT=dev:your-deployment-slug
PUBLIC_CONVEX_URL=https://your-deployment-slug.convex.cloud
PUBLIC_CONVEX_SITE_URL=https://your-deployment-slug.convex.site

# ----- Better Auth [convex] -----
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Must match the deployed site's URL (used by the auth handler to build callback URLs)
SITE_URL=http://localhost:5173
# Google OAuth (Better Auth social provider; AUTH_GOOGLE_SECRET is [convex])
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ----- Webhook auth [convex] -----
# Shared secret between the hub's verified provider/contact handlers and the
# Convex mutations they call. Gates orders.create / orders.updateStatus /
# platform.updateSubscription / platform.getBySubscriptionId /
# invoices.markPaid.
# Generate with: openssl rand -base64 32
# ALSO run: npx convex env set WEBHOOK_SECRET <value>
WEBHOOK_SECRET=

# Dedicated least-privilege capability for the hub's customer order lookup.
# Keep hub/Convex-only; never distribute it to a spoke or browser.
# ALSO run: npx convex env set ORDER_LOOKUP_SECRET <value>
ORDER_LOOKUP_SECRET=

# Hub-only JSON registry for trusted spoke sites that ask the hub to create
# connected-account print checkout sessions. Every tenant receives a unique
# secret and explicit success/cancel redirect origins. Keep at most two secrets
# per tenant during rotation. Example:
# {"client.example":{"secrets":["unique-32-byte-minimum"],"redirectOrigins":["https://client.example"]}}
CHECKOUT_BRIDGE_TENANTS=

# ----- Sanity CMS -----
PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production
# Viewer-with-drafts token used for preview mode.
SANITY_PREVIEW_TOKEN=

# ----- Stripe -----
# Use sk_test_... / pk_test_... locally. Use sk_live_... / pk_live_... only in
# production deployment. Never commit either. STRIPE_SECRET_KEY is also read by
# the Convex fee-capture action and must be set on that deployment.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLIC_KEY=pk_test_xxx
PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxx
# Webhook signing secrets — one per Stripe webhook endpoint configured in the
# Stripe dashboard. Retrieve each by clicking into the endpoint.
# Commerce checkout webhook. STRIPE_CONNECT_WEBHOOK_SECRET is optional during
# rollout; when set it takes precedence for /api/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PLATFORM_WEBHOOK_SECRET=

# ----- Resend (transactional email) -----
RESEND_API_KEY=

# ----- LumaPrints (print fulfillment) -----
LUMAPRINTS_API_KEY=
LUMAPRINTS_API_SECRET=
LUMAPRINTS_STORE_ID=
# Set to "true" to route all LumaPrints API calls through the sandbox endpoint.
LUMAPRINTS_USE_SANDBOX=true
# Basic credentials configured on the hub-owned LumaPrints shipping webhook.
# These are distinct from the outbound API key/secret above.
LUMAPRINTS_WEBHOOK_USERNAME=
LUMAPRINTS_WEBHOOK_PASSWORD=
# Optional, temporary overlap for a no-downtime password rotation. Remove it
# immediately after the provider has been verified with the current password.
LUMAPRINTS_WEBHOOK_PASSWORD_PREVIOUS=

# ----- Gallery Worker (Cloudflare Worker for R2 uploads) -----
GALLERY_WORKER_URL=https://gallery-worker.your-subdomain.workers.dev
GALLERY_WORKER_TOKEN=
# Secret used to authenticate admin upload requests.
GALLERY_ADMIN_SECRET=
# Token for the Sharp border-compositor hot-path.
SHARP_SPIKE_TOKEN=

# ----- CMS Media Worker (public-site Editor uploads) -----
# Per-site server credential for the shared CMS media Worker. This is distinct
# from GALLERY_ADMIN_SECRET and must match the angelsrest.online tenant entry in
# the Worker's CMS_MEDIA_TENANT_SECRETS registry. Never expose it to the browser.
CMS_MEDIA_WORKER_SECRET=

# Server-only, site-unique capability used by this host after the Worker has
# removed every object in a deletion manifest. Never expose it to the browser.
CMS_MEDIA_DELETION_COMPLETION_SECRET=
# Convex-only tenant registry for those capabilities. Keep at most two unique
# 32-byte-or-longer secrets per tenant during rotation. The host receives only
# its singular secret above; no spoke receives this complete registry.
# ALSO run: npx convex env set CMS_MEDIA_DELETION_COMPLETION_SECRETS '<json>'
# Example: {"angelsrest.online":["unique-32-byte-minimum"]}
CMS_MEDIA_DELETION_COMPLETION_SECRETS=

# Convex-only, purpose-separated tenant registries for private catalog receipt
# sets. The storage producer and independent inspector must receive different
# site credentials; a secret reused across either role or tenant fails closed.
# ALSO run each command against the shared Convex deployment:
# npx convex env set CATALOG_PRIVATE_ASSET_STORAGE_RECEIPT_SECRETS '<json>'
# npx convex env set CATALOG_PRIVATE_ASSET_INSPECTION_RECEIPT_SECRETS '<json>'
CATALOG_PRIVATE_ASSET_STORAGE_RECEIPT_SECRETS=
CATALOG_PRIVATE_ASSET_INSPECTION_RECEIPT_SECRETS=

# Convex-only editor upload journal roles. The host credential can reserve,
# project, and dispatch storage work; the inspector credential can claim only
# inspection work. The Worker control credential is held by Convex and the CMS
# media Worker only: do not mirror it into a host, spoke, or browser environment.
# The Worker's CATALOG_PRIVATE_EDITOR_UPLOAD_CONTROL_SECRETS must contain the
# same per-tenant value so Convex can run /prepare inside the journal boundary.
# ALSO run each command against the shared Convex deployment:
# npx convex env set CATALOG_PRIVATE_ASSET_EDITOR_HOST_JOURNAL_SECRETS '<json>'
# npx convex env set CATALOG_PRIVATE_ASSET_EDITOR_INSPECTION_CLAIM_SECRETS '<json>'
# npx convex env set CATALOG_PRIVATE_EDITOR_UPLOAD_CONTROL_SECRETS '<json>'
CATALOG_PRIVATE_ASSET_EDITOR_HOST_JOURNAL_SECRETS=
CATALOG_PRIVATE_ASSET_EDITOR_INSPECTION_CLAIM_SECRETS=
CATALOG_PRIVATE_EDITOR_UPLOAD_CONTROL_SECRETS=

# Host-only, singular credentials for the same-origin private Editor upload
# bridge. The journal value must match this site's entry in the Convex host
# registry above; the storage value must match this site's dedicated Worker
# storage-caller entry. They must be distinct from each other and every other
# authority. Do not give this host inspector, receipt, sealing, broad tenant, or
# Worker-control credentials.
CATALOG_PRIVATE_EDITOR_UPLOAD_HOST_JOURNAL_SECRET=
CATALOG_PRIVATE_EDITOR_UPLOAD_STORAGE_CALLER_SECRET=
# Global Convex authority-separation invariant: every current/previous value in
# these journal registries, both receipt registries, and
# CMS_MEDIA_DELETION_COMPLETION_SECRETS must be distinct from every other value
# and from BETTER_AUTH_SECRET, AUTH_GOOGLE_SECRET, STRIPE_SECRET_KEY,
# WEBHOOK_SECRET, and ORDER_LOOKUP_SECRET. Those five configured scalars must
# also be pairwise distinct. Any overlap fails the shared gate closed for Better
# Auth, webhook/order lookup, fee capture, journal, receipt, and deletion
# authority until rotation is corrected. During rotation, add a unique previous
# value, update both consumers, switch current, then remove the old value.

# ----- Notifications -----
# Admin email that receives order/contact notifications.
NOTIFICATION_EMAIL=admin@example.com

# ----- Sentry -----
# Optional. Leave empty to disable error capture entirely (no-op).
# Per-deployment DSN: each Vercel project sets its own value, so client-site
# deployments can route to their own Sentry project without code changes.
PUBLIC_SENTRY_DSN=
# Set in CI for Sentry source map upload (not needed in runtime env).
# SENTRY_AUTH_TOKEN=
