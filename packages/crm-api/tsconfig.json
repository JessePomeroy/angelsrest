{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		// Type-check-only config. The real build pipeline (Phase 2) lives in
		// tsconfig.build.json, which sets noEmit:false + outDir + rootDir to
		// emit into dist/. After the Gap 2 Phase 1 relocation, src/*.ts
		// re-exports from ../convex/_generated/* (within-package), so the
		// historical "noEmit trap" no longer applies.
		"noEmit": true
	},
	"include": ["src/**/*", "convex/**/*"],
	"exclude": ["node_modules", "dist", "convex/_generated/*.js"]
}
