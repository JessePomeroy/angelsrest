{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		// This package intentionally ships TypeScript source to known
		// Vite/SvelteKit consumers. Keep this config type-check-only; there is no
		// tsconfig.build.json or dist emission step.
		"noEmit": true
	},
	"include": ["src/**/*", "convex/**/*"],
	"exclude": ["node_modules", "dist", "convex/_generated/*.js"]
}
