# ============================================================================
# packages/crm-api — local Convex CLI environment
# ============================================================================
# `npx convex dev` must run from this directory (post Gap 2 Phase 1) so the
# CLI can find the convex/ source tree. The CLI reads CONVEX_DEPLOYMENT from
# the CWD's .env.local — i.e. *this* directory, not the angelsrest root —
# so a copy lives here in addition to angelsrest/.env.local.
#
# Copy this file to .env.local and replace the placeholder with the dev
# deployment slug from your `npx convex dev` setup output.
# ============================================================================

CONVEX_DEPLOYMENT=dev:your-deployment-slug # team: <team>, project: angelsrest-crm
