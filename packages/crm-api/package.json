{
	"name": "@jessepomeroy/crm-api",
	"version": "2.11.0",
	"description": "Generated Convex API types for the photographer CRM platform. Consumed by spoke sites (reflecting-pool, future clients).",
	"type": "module",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./api": {
			"types": "./src/api.ts",
			"default": "./src/api.ts"
		},
		"./dataModel": {
			"types": "./src/dataModel.ts",
			"default": "./src/dataModel.ts"
		},
		"./server": {
			"types": "./src/server.ts",
			"default": "./src/server.ts"
		}
	},
	"files": [
		"src/",
		"convex/**/*.ts",
		"convex/_generated/"
	],
	"scripts": {
		"prepublishOnly": "tsc -p tsconfig.json --noEmit"
	},
	"peerDependencies": {
		"convex": "^1.30.0"
	},
	"dependencies": {
		"stripe": "^20.4.1"
	},
	"devDependencies": {
		"convex": "^1.42.1",
		"typescript": "^5.9.3"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/jessepomeroy/angelsrest.git",
		"directory": "packages/crm-api"
	}
}
