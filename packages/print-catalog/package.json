{
	"name": "@jessepomeroy/print-catalog",
	"version": "0.2.0",
	"description": "Shared LumaPrints print catalog, pricing, and margin helpers for photographer CRM sites and Studios.",
	"type": "module",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./pricing": {
			"types": "./src/pricing.ts",
			"default": "./src/pricing.ts"
		}
	},
	"files": [
		"src/index.ts",
		"src/pricing.ts"
	],
	"scripts": {
		"check": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run",
		"prepublishOnly": "pnpm check && pnpm test"
	},
	"devDependencies": {
		"typescript": "^5.9.3",
		"vitest": "^4.1.9"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/jessepomeroy/angelsrest.git",
		"directory": "packages/print-catalog"
	}
}
