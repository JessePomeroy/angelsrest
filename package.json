{
	"name": "angelsrest",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@skeletonlabs/skeleton": "^4.15.2",
		"@skeletonlabs/skeleton-svelte": "^4.15.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"dotenv": "^17.4.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.2",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@convex-dev/better-auth": "^0.11.5",
		"@jessepomeroy/admin": "link:../admin-dashboard",
		"@lucide/svelte": "^0.563.1",
		"@mmailaender/convex-better-auth-svelte": "^0.7.3",
		"@mmailaender/convex-svelte": "^0.18.0",
		"@portabletext/svelte": "^3.0.1",
		"@sanity/client": "^7.21.0",
		"@sanity/image-url": "^2.1.1",
		"@sanity/preview-url-secret": "^4.0.5",
		"@sanity/visual-editing": "^5.3.4",
		"@sentry/sveltekit": "^10.50.0",
		"@stripe/stripe-js": "^8.11.0",
		"@tailwindcss/typography": "^0.5.19",
		"@vercel/analytics": "^1.6.1",
		"better-auth": "1.5.3",
		"convex": "^1.36.0",
		"isomorphic-dompurify": "^3.10.0",
		"resend": "^6.12.2",
		"sharp": "^0.34.5",
		"stripe": "^20.4.1",
		"svelte-dnd-action": "^0.9.69"
	},
	"lint-staged": {
		"!(convex/_generated/**)*.{js,ts}": [
			"biome check --no-errors-on-unmatched"
		],
		"*.svelte": [
			"svelte-check --tsconfig ./tsconfig.json"
		]
	},
	"pnpm": {
		"overrides": {
			"uuid@<14.0.0": "^14.0.0",
			"cookie@<0.7.0": "^0.7.0"
		}
	}
}
