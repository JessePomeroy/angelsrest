{
  "name": "angelsrest",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@skeletonlabs/skeleton": "^4.11.0",
    "@skeletonlabs/skeleton-svelte": "^4.11.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "dotenv": "^17.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "svelte": "^5.48.2",
    "svelte-check": "^4.3.5",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.11.4",
    "@jessepomeroy/admin": "^0.7.3",
    "@lucide/svelte": "^0.563.1",
    "@mmailaender/convex-better-auth-svelte": "^0.7.2",
    "@mmailaender/convex-svelte": "^0.18.0",
    "@portabletext/svelte": "^3.0.1",
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.0.3",
    "@sanity/preview-url-secret": "^4.0.4",
    "@sanity/visual-editing": "^5.3.3",
    "@stripe/stripe-js": "^8.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/dompurify": "^3.2.0",
    "@vercel/analytics": "^1.6.1",
    "better-auth": "1.5.3",
    "convex": "^1.34.1",
    "convex-svelte": "^0.0.12",
    "isomorphic-dompurify": "^3.7.1",
    "resend": "^6.9.1",
    "stripe": "^20.3.0",
    "svelte-dnd-action": "^0.9.69"
  },
  "lint-staged": {
    "!(convex/_generated/**)*.{js,ts}": [
      "biome check --no-errors-on-unmatched"
    ],
    "*.svelte": [
      "svelte-check --tsconfig ./tsconfig.json"
    ]
  }
}
