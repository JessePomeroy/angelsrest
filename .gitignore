node_modules

# Output
.output
.vercel
.netlify
.wrangler
.svelte-kit
/build

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.claude/worktrees/

# Local audit/rotation working docs may contain sensitive provider details.
AUDIT.md
ROTATION.md

# Guard against accidental TypeScript output inside Convex source. The package
# is type-check-only; emitted siblings confuse Convex's entry-point scan.
packages/crm-api/convex/**/*.js
packages/crm-api/convex/**/*.d.ts
packages/crm-api/convex/**/*.d.ts.map
!packages/crm-api/convex/convex.config.ts
!packages/crm-api/convex/_generated/

# The canonical Convex tree lives in packages/crm-api/. Running Convex commands
# from the repository root can bootstrap an empty root-level tree, so ignore it
# and always run those commands from packages/crm-api/.
/convex/
